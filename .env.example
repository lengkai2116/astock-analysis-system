# ============================================
# A股分析系统 — 环境变量模板
# ============================================
# 复制为 .env 后填入真实 API Key 即可使用
# 首次启动时 start.bat / start.command 会自动完成

# ---- 数据库（SQLite 零配置，默认即可） ----
DATABASE_URL=sqlite:///test.db

# ---- 数据缓存目录（默认项目根目录下的 data/ 文件夹） ----
DATA_DIR=data

# ---- Flask ----
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-string

# ---- Tushare Pro 数据源 ----
TUSHARE_TOKEN=your-tushare-token-here

# ---- DeepSeek AI 分析 ----
LLM_PROVIDER=mock
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat-v4-flash

# ---- 认证（留空 = 不启用） ----
AUTH_TOKEN=

# ---- CORS ----
CORS_ORIGIN=http://localhost:5001
